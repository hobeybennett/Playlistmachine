# Spotify API credentials (client credentials flow — no user auth required)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Neon Postgres connection string
# Create a database at https://neon.tech and copy the connection string
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# Secret used to authenticate Vercel cron job calls to /api/cron/poll
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
